# =============================================================================
# obs-overlay-kill 環境変数（コピーして .env にリネームし、値を入れてください）
# =============================================================================
#
# 【用語】
#   アプリ認証情報 … Twitch Developer Console（または Token Generator）の
#                     Client ID / Client Secret（アプリ単位・公開されない Secret）
#   ユーザートークン … あるチャンネル所有者アカウント向けの Access / Refresh
#                     （人間が OAuth か Generator で取得。Client Secret とは別物）
#
# --- Twitch Token Generator（https://twitchtokengenerator.com）の画面 → このファイル ---
# 「Use My Client Secret and Client ID」欄 … あなたの Dev Console アプリを Generator に渡す
#   CLIENT ID     → VITE_TWITCH_TOKEN_APP_CLIENT_ID（または VITE_TWITCH_CLIENT_ID）
#   CLIENT SECRET → VITE_TWITCH_TOKEN_APP_CLIENT_SECRET（または VITE_TWITCH_CLIENT_SECRET）
#   ※ 同じアプリの OAuth Redirect に https://twitchtokengenerator.com を追加すること（サイトの案内どおり）
#
# 「Generated Tokens」欄 … 認証後に出る「人間用トークン」と「API 用の確認表示」
#   ACCESS TOKEN  → VITE_TWITCH_ACCESS_TOKEN
#   REFRESH TOKEN → VITE_TWITCH_REFRESH_TOKEN
#   CLIENT ID     → .env 用の「第3の変数」ではない。Helix は「Access Token がどのアプリ向けか」と
#                   Client-Id ヘッダを一致させる必要があるため、サイトが同じ ID をもう一度表示している。
#   「Use My Client …」を使っていれば、ここの CLIENT ID は上の TOKEN_APP の Client ID と同じ文字列のはず。
#   自分のアプリを使わずデフォルトで生成した場合だけ、Generator 側アプリの Client ID が出る。
#
# 【必須】トークン用アプリ（次の A または B のどちらか一方）
#   OAuth リフレッシュ・チャット送信・チャンネルポイント等で使う Client ID/Secret。
#   ユーザートークンは「このアプリの Client ID」と紐づいている必要があります。
#
#   (A) 推奨: Token Generator でトークンを取ったアプリと揃える
VITE_TWITCH_TOKEN_APP_CLIENT_ID=your_token_app_client_id_here
VITE_TWITCH_TOKEN_APP_CLIENT_SECRET=your_token_app_client_secret_here
#
#   (B) 代替: (A) を未設定にしたときだけ読み込まれる従来名
# VITE_TWITCH_CLIENT_ID=your_client_id_here
# VITE_TWITCH_CLIENT_SECRET=your_client_secret_here
#
# 【任意】コンソール用の別アプリ（ユーザー検索等で Helix に別 Client-Id が欲しい場合）
#   両方セットしたときだけ使用。未設定ならトークン用アプリにフォールバック。
# VITE_TWITCH_CONSOLE_CLIENT_ID=your_console_client_id_here
# VITE_TWITCH_CONSOLE_CLIENT_SECRET=your_console_client_secret_here
#
# 【推奨】チャンネル所有者のユーザートークン（Generator またはアプリ内 OAuth）
#   Client ID / Secret と値を取り違えないこと（Access は通常もっと長い文字列）。
VITE_TWITCH_ACCESS_TOKEN=
VITE_TWITCH_REFRESH_TOKEN=
VITE_TWITCH_USERNAME=your_login_name
#
# --- アプリ全般（任意）---
# VITE_DEFAULT_CHANNEL=your_channel_login
# VITE_AUTO_REFRESH_INTERVAL=30
# VITE_MAX_CHAT_MESSAGES=100
#
# --- オーバーレイ / 開発用（任意）---
# テストモードはオーバーレイ設定 UI の「テスト」で有効化（このキーは現状未使用）
OVERLAY_TEST_MODE=true
# VITE_OVERLAY_EMBEDDED_SETTINGS_IN_PROD=true
# VITE_OVERLAY_SETTINGS_DEFAULT_EXPANDED=true
# VITE_OVERLAY_SETTINGS_TAB=streamer
# クエリ: ?openSettings=1&settingsTab=user / ?testPanel=1
