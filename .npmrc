# npm サプライチェーン対策（プロジェクト共通）
# 参考: https://qiita.com/masato_makino/items/516ca6f8a8b497131602

# ライフサイクルスクリプト（postinstall 等）を実行しない
ignore-scripts=true

# 公開から 7 日未満のバージョンはインストール拒否（npm >= 11.10.0）
min-release-age=7

# package-lock.json のみから再現可能にインストール（npm ci 推奨）
package-lock=true

# 監査・通知
audit-level=moderate
fund=false

# engines フィールドを厳守
engine-strict=true
